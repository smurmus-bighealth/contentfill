# =============================================================================
# Contentful — target space
# =============================================================================

# Which space to operate on
CONTENTFUL_SPACE_ID=your_space_id_here

# Which Contentful environment to target (default: master)
# Use a non-production environment (e.g. "staging") for testing
CONTENTFUL_ENVIRONMENT=master

# =============================================================================
# Auth
# =============================================================================

# Required in all environments. Auth.js validates this at middleware startup
# before any request is handled, even in local dev where no sessions are created.
# Generate: openssl rand -base64 32
# Never reuse across environments. Never commit a real value.
AUTH_SECRET=

# ── Option A: Contentful OAuth (recommended for deployed instances) ──────────
#
# Enforces that users authenticate with their own Contentful account and are
# verified as members of CONTENTFUL_SPACE_ID before accessing the tool.
# Contentful's own RBAC then governs what each user can do.
#
# Setup:
#   1. Create an OAuth app at:
#      https://app.contentful.com/account/profile/developers/applications/new
#   2. Set Redirect URI to: {YOUR_URL}/api/auth/callback/contentful
#   3. Fill in the three vars below and leave Option B vars unset.
#
# CONTENTFUL_OAUTH_CLIENT_ID=
# CONTENTFUL_OAUTH_CLIENT_SECRET=
#
# AUTH_URL — canonical URL of your deployment (e.g. https://contentfill.example.com).
#            Without this, callback URLs are inferred from request headers,
#            which can be spoofed behind a reverse proxy.
# AUTH_URL=

# ── Option B: Personal access token (local dev only) ─────────────────────────
#
# Simpler setup for local development.
# The management token is the credential gate — no additional auth check is performed.
#
# Get a token: Contentful → Settings → API keys → Content Management Tokens
# Never expose this value client-side.
CONTENTFUL_MANAGEMENT_TOKEN=your_cma_token_here

# =============================================================================
# Optional: AI-assisted transform generation
# =============================================================================
# ANTHROPIC_API_KEY=
