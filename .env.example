# =============================================================================
# Contentful Management API (write access — never expose client-side)
# Get from: Contentful dashboard → Settings → API keys → Content Management Tokens
# =============================================================================
CONTENTFUL_MANAGEMENT_TOKEN=your_cma_token_here

# Same space ID as NEXT_PUBLIC_SPACE_ID in canopy
CONTENTFUL_SPACE_ID=your_space_id_here

# Which Contentful environment to target (default: master)
# Use a non-production env (e.g. "staging") for testing
CONTENTFUL_ENVIRONMENT=master

# =============================================================================
# Optional: protect the admin UI when deployed (e.g. to Vercel)
# Leave unset for local dev — no auth check will be performed
# =============================================================================
# ADMIN_SECRET=choose_a_strong_secret_here
